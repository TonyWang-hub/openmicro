# codex-micro-sim Host 环境变量样例
# 用法：cp .env.example .env，按需修改值；scripts/start.sh 会自动 source 本文件。
# 完整变量语义/设计动机见 docs/DEPLOY.md 的“环境变量”小节，这里只给取值样例 + 一句话提醒。

# ---------- 网络 / 鉴权 ----------

# 绑定地址。默认只监听本机 loopback（127.0.0.1），是默认安全姿态。
# ⚠️ 改成 0.0.0.0（局域网/手机才能连上）之前，必须同时把下面的 CMS_TOKEN
#    固定成一个非空值——否则没有其他鉴权机制，局域网内任何人拿到 IP:端口
#    就能连上、看到你的会话内容甚至远程注入按键。
CMS_HOST=127.0.0.1

# HTTP + WS 监听端口。
CMS_PORT=7788

# Live 模式配对 token。留空 = 每次启动随机生成（8 字节 hex），重启后旧的
# 配对链接/二维码全部失效。局域网长期使用建议固定一个值自己保管好。
CMS_TOKEN=

# ---------- 状态机时序（毫秒） ----------

# complete（绿灯）态展示多久后自动回落到 idle。
CMS_COMPLETE_HOLD_MS=2000

# 非 idle/unknown/needs_input 态超过这么久没收到新的 ingest 事件，
# 判定为 unknown（视为 ingest 断流的心跳超时）。
CMS_INGEST_STALE_MS=30000

# ---------- 可选增强 ----------

# 设为 1 开启 codex app-server 可选增强 ingest 通道。
# ⚠️ 当前默认 transport 尚未真正实现（见 docs/ARCHITECTURE.md §5），
#    保持默认关闭即可，开了也暂时没有实际效果。
CMS_CODEX_APP_SERVER=0

# ---------- 会话相关 ----------

# new_session 命令新开会话时使用的默认工作目录。
# 留空则用 Host 进程启动时所在目录（process.cwd()）。
CMS_DEFAULT_CWD=

# 预留数据目录，当前实现未见落盘使用，按需扩展。默认 ~/.cms。
CMS_DATA_DIR=

# accept/reject 按键序列覆盖（JSON 字符串），深合并到内置默认 keymap。
# 例：CMS_KEYMAP='{"codex":{"accept":["y","Enter"]}}'
# 内置默认：claude-code accept=["1"] reject=["Escape"]；
#          codex        accept=["y"] reject=["Escape"]
CMS_KEYMAP=

# new_session / branch 命令对各 agent 槽实际执行的启动命令。
CMS_CMD_CLAUDE=claude
CMS_CMD_CODEX=codex

# cmux CLI 可执行文件路径。留默认 "cmux" 时优先找 PATH 里的 cmux，
# 找不到再退回 macOS 应用包内路径
# /Applications/cmux.app/Contents/Resources/bin/cmux。
CMS_CMUX_BIN=cmux

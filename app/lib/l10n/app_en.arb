{
    "@@locale": "en",

    "connectSubtitle": "Connect to your Host",
    "@connectSubtitle": {
        "description": "Subtitle under the app title on the connect screen"
    },

    "pairUrlLabel": "Pairing link (from the /pair QR code on your computer)",
    "@pairUrlLabel": {
        "description": "Label for the pairing URL text field"
    },

    "tokenLabel": "Token (if not included in the link)",
    "@tokenLabel": {
        "description": "Label for the token text field"
    },

    "parseErrorText": "Failed to parse: paste the pairing link (with ?token=), or fill in host:port + token",
    "@parseErrorText": {
        "description": "Error shown when the pairing input can't be parsed"
    },

    "connectButton": "Connect",
    "@connectButton": {
        "description": "Label for the connect button"
    },

    "scanButton": "Scan QR",
    "@scanButton": {
        "description": "Label for the scan-QR button"
    },

    "connectFooterHint": "Your phone must be on the same LAN as the Host. You can also tap \"Scan QR\" to scan the /pair page QR code on your computer directly.",
    "@connectFooterHint": {
        "description": "Footer hint on the connect screen"
    },

    "lcdConnecting": "LIVE · Connecting…",
    "@lcdConnecting": {
        "description": "LCD status text while the initial connection is being established"
    },

    "lcdConnected": "LIVE · Connected",
    "@lcdConnected": {
        "description": "LCD status text once connected"
    },

    "lcdNoData": "Connected but no data — check whether the Host is running / token is correct",
    "@lcdNoData": {
        "description": "LCD status text when connected but no state frame arrives in time"
    },

    "lcdDisconnectedReconnecting": "Disconnected, reconnecting…(lights held)",
    "@lcdDisconnectedReconnecting": {
        "description": "LCD status text while reconnecting after a dropped connection"
    },

    "needsInputAlert": "{name} needs you — select it, then press ◎✓/⊗",
    "@needsInputAlert": {
        "description": "LCD alert when an agent slot transitions to needing input",
        "placeholders": {
            "name": {
                "type": "String"
            }
        }
    },

    "selectedAgent": "Selected {name} (◎✓/⊗ only affects it)",
    "@selectedAgent": {
        "description": "LCD feedback after tapping an agent light",
        "placeholders": {
            "name": {
                "type": "String"
            }
        }
    },

    "selectAgentFirstKey": "Tap an Agent light to select it first, then press this key",
    "@selectAgentFirstKey": {
        "description": "LCD feedback when a command key is pressed with no focused agent"
    },

    "acceptSent": "◎✓ Accept → agent {slot}",
    "@acceptSent": {
        "description": "LCD feedback after sending the accept command",
        "placeholders": {
            "slot": {
                "type": "int"
            }
        }
    },

    "rejectSent": "⊗ Reject → agent {slot}",
    "@rejectSent": {
        "description": "LCD feedback after sending the reject command",
        "placeholders": {
            "slot": {
                "type": "int"
            }
        }
    },

    "quickSent": "⚡ Continue (Enter) → agent {slot}",
    "@quickSent": {
        "description": "LCD feedback after sending the quick-continue command",
        "placeholders": {
            "slot": {
                "type": "int"
            }
        }
    },

